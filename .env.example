# Required for news and stocks widgets
GNEWS_API_KEY=your_gnews_key_here
FINNHUB_API_KEY=your_finnhub_key_here

# Required for the daily quote card
API_NINJAS_API_KEY=your_api_ninjas_key_here

# Calendar: private ICS URL (Google Calendar "Secret address in iCal format" or iCloud share link)
# Replace webcal:// with https:// for iCloud URLs
CALENDAR_ICS_URL=

# Location for weather and sunrise (defaults to San Francisco)
LATITUDE=37.7749
LONGITUDE=-122.4194

# IANA timezone for calendar date filtering (e.g. America/New_York, America/Los_Angeles)
# Required when the server runs in UTC (e.g. Docker) but your calendar is in a different timezone.
# Defaults to the server's local timezone.
TIMEZONE=

# Server port
PORT=8080

# SQLite database file path (relative to working directory or absolute)
# Defaults to dashboard.db in the current directory
SQLITE_PATH=dashboard.db

# Google OAuth (required for authentication)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:8080/api/auth/callback

# Session cookie signing key — generate with: openssl rand -hex 32
SESSION_SECRET=change_me_to_a_random_32_byte_hex_string

# Frontend URL for post-login redirect
FRONTEND_URL=http://localhost:5173

# Allowed CORS origin for the API server (set to your frontend URL in production)
CORS_ORIGIN=http://localhost:5173

# Encryption key for sensitive fields (calendar ICS URLs) — generate with: openssl rand -hex 32
# Optional: if unset, sensitive fields are stored in plaintext (not recommended for production)
ENCRYPTION_KEY=
